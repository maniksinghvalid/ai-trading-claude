# AI Trading Claude — local environment
# Copy this file to `.env` and fill in real values; `.env` is gitignored.
# Full config table: plan/portfolio-routine-and-vector-memory.md §1.

# --- REQUIRED for slice 3a (Pinecone memory layer) ---
# Get from https://app.pinecone.io → Project → API keys
# (Producer needs read+write; consumers use a separate Reader-role key.)
PINECONE_API_KEY=pcsk_PLACEHOLDER_REPLACE_ME

# --- OPTIONAL; defaults shown match plan §1 ---
# PINECONE_INDEX=trade-reports
# PINECONE_EMBED_MODEL=llama-text-embed-v2
# PINECONE_CLOUD=aws
# PINECONE_REGION=us-east-1
# PINECONE_NAMESPACE=trade

# --- OPTIONAL; Drive archive (slice 3b+) ---
# TRADE_DRIVE_ARCHIVE_FOLDER_ID=

# --- CLOUD-ROUTINE ONLY (slice 7.5+); never set these locally ---
# When PINECONE_PROXY_URL is set together with PINECONE_PROXY_TOKEN,
# trade_memory.py routes via the Vercel proxy instead of the SDK.
# Local use should leave both unset and use PINECONE_API_KEY directly.
# PINECONE_PROXY_URL=
# PINECONE_PROXY_TOKEN=

# --- OPTIONAL: Vercel Deployment Protection bypass (slice 7.5+) ---
# If the Vercel project has Deployment Protection enabled and you've
# generated a "Protection Bypass for Automation" token, paste it here.
# trade_memory.py will attach the `x-vercel-protection-bypass` header to
# every proxy request. Leave commented if Deployment Protection is OFF
# on the proxy project.
#
# Generate via: Vercel dashboard → project → Settings →
#   Deployment Protection → "Protection Bypass for Automation" → Add
# VERCEL_PROTECTION_BYPASS=
