# proxy/.env.example — template for local dev only.
# DEPLOYMENT secrets live in Vercel project settings, NOT in any .env file
# checked into git or copied into the repo.

# REQUIRED on the deployed proxy:
PINECONE_API_KEY=pcsk_...        # the producer's full-access Pinecone key
PROXY_AUTH_TOKEN=                 # 32-char hex from `openssl rand -hex 32`

# OPTIONAL (rate limiting; without these the proxy logs a one-line warning
# and allows all requests — see proxy/_lib/ratelimit.py):
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# OPTIONAL (override the index name; defaults to trade-reports):
# PINECONE_INDEX=trade-reports

# OPTIONAL (deploy-time override for the trade_schemas.py path; the
# vercel.json includeFiles already handles the default Vercel runtime
# layout):
# TRADE_SCHEMAS_PATH=/var/task/scripts/trade_schemas.py
